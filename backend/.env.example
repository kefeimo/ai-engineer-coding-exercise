# LLM Configuration
LLM_PROVIDER=gpt4all  # Options: gpt4all, openai
GPT4ALL_MODEL=mistral-7b-instruct-v0.1.Q4_0.gguf
OPENAI_API_KEY=your_openai_api_key_here  # Optional, for OpenAI provider

# Embedding Configuration
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ChromaDB Configuration
CHROMA_PERSIST_DIRECTORY=./data/chroma_db
CHROMA_COLLECTION_NAME=fastapi_docs

# RAG Configuration
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RESULTS=5
CONFIDENCE_THRESHOLD=0.65

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=INFO

# Evaluation
RAGAS_METRICS=context_precision,faithfulness,answer_relevancy
